# Anthropic API key — required for resume fit scoring and new-job detection
# Get yours at https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google OAuth Client ID — required for Gmail email sync (PKCE flow, no secret needed)
# Application type must be "Web application" with http://localhost:5173 as both
# an Authorized JavaScript origin and an Authorized redirect URI.
# See src/utils/googleAuth.js for full setup instructions.
VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
