# Anthropic API key — required for resume fit scoring and new-job detection
# Get yours at https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google OAuth credentials — required for Gmail email sync
# Application type must be "Desktop app" (not "Web application")
# See src/utils/googleAuth.js for full setup instructions (~10 min)
VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=your_client_secret
